{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "studio": "Made Thought",
    "location": "London",
    "collection": "MT/Tokens",
    "version": "1.0.0",
    "canvas": "1920x1080 slide presentation system"
  },
  "color": {
    "surface": {
      "$type": "color",
      "$value": { "light": "#ffffff", "dark": "#000000" },
      "$description": "Slide background fill"
    },
    "ink": {
      "$type": "color",
      "$value": { "light": "#000000", "dark": "#ffffff" },
      "$description": "Primary text, strokes, icons"
    },
    "ink-subtle": {
      "$type": "color",
      "$value": {
        "light": "rgba(102, 102, 102, 0.4)",
        "dark": "rgba(153, 153, 153, 0.6)"
      },
      "$description": "Secondary text, captions, metadata"
    },
    "divider": {
      "$type": "color",
      "$value": {
        "light": "rgba(235, 235, 235, 0.92)",
        "dark": "rgba(31, 31, 31, 0.12)"
      },
      "$description": "Card backgrounds, dividers, grid cell fills"
    },
    "palette": {
      "white": {
        "$type": "color",
        "$value": "#ffffff",
        "$description": "Static white — never theme-swapped"
      },
      "black": {
        "$type": "color",
        "$value": "#000000",
        "$description": "Static black — never theme-swapped"
      }
    }
  },
  "typography": {
    "fontFamily": {
      "display": {
        "$type": "fontFamily",
        "$value": ["Items MT", "Georgia", "serif"],
        "$description": "Emotional register — display headlines, hero numbers"
      },
      "ui": {
        "$type": "fontFamily",
        "$value": ["Futura PT", "Helvetica Neue", "Arial", "sans-serif"],
        "$description": "Functional register — labels, body, footers"
      }
    },
    "fontWeight": {
      "light": { "$type": "fontWeight", "$value": 300 },
      "book": { "$type": "fontWeight", "$value": 400 },
      "demi": { "$type": "fontWeight", "$value": 600 }
    },
    "fontSize": {
      "display-mega": { "$type": "dimension", "$value": "180px", "$description": "Hero numbers, mega stats, single-word statements" },
      "display-xl": { "$type": "dimension", "$value": "68px", "$description": "Primary slide headline" },
      "display-m": { "$type": "dimension", "$value": "46px", "$description": "Secondary headline, section title" },
      "page-title": { "$type": "dimension", "$value": "22px", "$description": "PAGE TITLE label — uppercase, tracked" },
      "eyebrow": { "$type": "dimension", "$value": "22px", "$description": "EYEBROW LABEL — uppercase, tracked" },
      "body": { "$type": "dimension", "$value": "28px", "$description": "Body copy" },
      "footer": { "$type": "dimension", "$value": "12px", "$description": "Footer line" }
    },
    "letterSpacing": {
      "display": { "$type": "dimension", "$value": "-0.01em" },
      "ui": { "$type": "dimension", "$value": "0.08em", "$description": "For uppercase labels" },
      "body": { "$type": "dimension", "$value": "0" }
    }
  },
  "spacing": {
    "0": { "$type": "dimension", "$value": "0px" },
    "1": { "$type": "dimension", "$value": "4px" },
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "16px" },
    "4": { "$type": "dimension", "$value": "24px" },
    "5": { "$type": "dimension", "$value": "32px" },
    "6": { "$type": "dimension", "$value": "48px" },
    "7": { "$type": "dimension", "$value": "60px" },
    "8": { "$type": "dimension", "$value": "80px" },
    "9": { "$type": "dimension", "$value": "120px" },
    "10": { "$type": "dimension", "$value": "160px" }
  },
  "slide": {
    "width": { "$type": "dimension", "$value": "1920px" },
    "height": { "$type": "dimension", "$value": "1080px" },
    "padding-x": { "$type": "dimension", "$value": "60px" },
    "padding-y": { "$type": "dimension", "$value": "60px" },
    "content-width": { "$type": "dimension", "$value": "1800px" },
    "gap-major": { "$type": "dimension", "$value": "80px" },
    "gap-minor": { "$type": "dimension", "$value": "24px" }
  }
}
